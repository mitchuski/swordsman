{
  "manifest_version": 3,
  "name": "Swordsman - Privacy Blade",
  "version": "0.1.0",
  "description": "Your sovereign privacy layer. Assert MyTerms, forge blades, guard the 7th capital.",

  "icons": {
    "16": "icons/sword-16.svg",
    "48": "icons/sword-48.svg",
    "128": "icons/sword-128.svg"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/sword-16.svg",
      "48": "icons/sword-48.svg"
    },
    "default_title": "Swordsman"
  },

  "background": {
    "service_worker": "dist/background/index.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/index.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "externally_connectable": {
    "ids": ["*"],
    "matches": ["http://localhost:5000/*", "https://agentprivacy.ai/*", "https://*.agentprivacy.ai/*"]
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*", "styles/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
