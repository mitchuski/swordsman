{
  "manifest_version": 3,
  "name": "Swordsman - Privacy Blade",
  "version": "0.3.1",
  "description": "Your sovereign privacy layer. Assert MyTerms, forge blades, guard the 7th capital. Bundles privacymage's grimoire (First Person + Zero + Canon + Society + Plurality) and the City of Mages grimoire v1.2.2 (Second Person · Tomes IV–V cast · two-tier collapse — archetype + mage · Luca 📐 at V0 · UOR Foundation as kindred substrate · SpaceComputer as kindred ecosystem · Aether ⊥ Celestial two-mana economy).",

  "icons": {
    "16": "icons/sword-16.svg",
    "48": "icons/sword-48.svg",
    "128": "icons/sword-128.svg"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/sword-16.svg",
      "48": "icons/sword-48.svg"
    },
    "default_title": "Swordsman"
  },

  "background": {
    "service_worker": "dist/background/index.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/index.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "externally_connectable": {
    "ids": ["*"],
    "matches": ["http://localhost:5000/*", "https://agentprivacy.ai/*", "https://*.agentprivacy.ai/*"]
  },

  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "styles/*",
        "privacymage_grimoire_v10_2_0.json",
        "city_of_mages_grimoire_v1_2_0.json"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
